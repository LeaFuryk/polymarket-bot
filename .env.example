# Anthropic API key (required for AI decisions)
POLYBOT_AI_API_KEY=sk-ant-...

# Polymarket CLOB API (read-only, no auth needed for public data)
# POLYBOT_MARKET_CONDITION_ID=0x...

# Optional overrides
# POLYBOT_AGENT_DECISION_INTERVAL=60
# POLYBOT_AGENT_INITIAL_CASH=10000.0
# POLYBOT_AI_MODEL=claude-sonnet-4-5-20250929

# --- Live Trading (optional — default is paper mode) ---
# POLYBOT_TRADING_MODE=live          # "paper" (default) or "live"
# POLYBOT_TRADING_PRIVATE_KEY=0x...  # Polygon wallet private key (from MetaMask)
# POLYBOT_TRADING_API_KEY=...        # CLOB API key (run: uv run python scripts/generate_api_key.py)
# POLYBOT_TRADING_API_SECRET=...     # CLOB API secret
# POLYBOT_TRADING_API_PASSPHRASE=... # CLOB API passphrase
# POLYBOT_TRADING_DRY_RUN=true       # Sign orders but don't post (test auth flow)
# POLYBOT_TRADING_MAX_ORDER_SIZE_USD=50.0
# POLYBOT_TRADING_MAX_SESSION_LOSS_USD=40.0

